# =============================================================================
# 后端环境变量配置
# 复制此文件为 .env 后根据需要修改；未设置的项将使用括号内的默认值
# 通过 pydantic-settings 自动加载，支持 .env 文件和系统环境变量
# =============================================================================

# -----------------------------------------------------------------------------
# 应用基本信息
# -----------------------------------------------------------------------------
APP_NAME=Decoration Project Management
APP_VERSION=1.0.0
APP_COMPONENT=backend

# -----------------------------------------------------------------------------
# 服务监听配置（本地开发有效；容器内被 Dockerfile 的 CMD 覆盖）
# -----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000

# -----------------------------------------------------------------------------
# CORS 允许的来源列表（英文逗号分隔）
# 默认已包含本地 5173(开发) / 4173(预览) / 3000(容器) 及 127.0.0.1 变体
# 生产部署请替换为实际域名，例如 https://app.example.com
# -----------------------------------------------------------------------------
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000
