# =============================================================================
# 前端环境变量配置
# 复制此文件为 .env 后根据需要修改；未设置的项将使用括号内的默认值
#
# 命名规则：VITE_ 前缀的变量会在构建时注入到前端代码中，非 VITE_ 仅在构建脚本可用
# =============================================================================

# -----------------------------------------------------------------------------
# 后端服务地址（仅本地开发/预览模式有效，容器部署由 Nginx 内部 DNS 解析）
# 本地开发时 Vite dev server 和 preview server 会把 /api、/docs、/openapi.json
# 代理到此地址。默认 http://127.0.0.1:8000
# -----------------------------------------------------------------------------
VITE_BACKEND_TARGET=http://127.0.0.1:8000

# -----------------------------------------------------------------------------
# API 基础路径（构建时注入，默认 /api）
# 前端代码中 fetch 请求会以 `${VITE_API_BASE_URL}/xxx` 的形式调用。
# 容器部署保持默认 /api 即可，由 Nginx 将 /api/ 转发到后端。
# 如需直接跨域访问独立后端，可填写完整地址，例如 https://api.example.com/v1
# -----------------------------------------------------------------------------
VITE_API_BASE_URL=/api
